# TikTok Developer App credentials
# Get these from https://developers.tiktok.com → Your App → Login Kit
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# Must be EXACTLY registered in your TikTok app's redirect URI list
# For local dev, TikTok allows http://localhost:<port>
TIKTOK_REDIRECT_URI=http://localhost:3000/auth/tiktok/callback

# A long random string for signing session cookies
SESSION_SECRET=change_this_to_a_long_random_secret_string

PORT=3000
